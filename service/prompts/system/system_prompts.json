{
  "prompt_templates": {
    "tfl_file_selection": {
      "name": "TFL文件选择提示词模板",
      "description": "用于从文件列表中选择最相关的TFL文件的提示词模板",
      "usage": "TFL文件选择和匹配",
      "used_by": ["LLMService", "DataExtractorV2"],
      "template": {
        "md_file": "prompt/tfl_selection_prompt.md"
      },
      "variables": ["title", "file_list"],
      "file_list_variables": ["index", "filename", "file_title"]
    },
    "data_extraction": {
      "name": "方案原文/结论提取模板",
      "description": "用于从标记后的方案全文中提取原文或结论（统一模板）",
      "usage": "方案原文提取与结论生成",
      "used_by": ["DataExtractorV2"],
      "template": {
        "md_file": "prompt/study_plan_extraction_prompt.md"
      },
      "variables": ["user_query", "process_type", "scheme_content", "project_desc"]
    },
    
    
    "tfl_processing": {
      "name": "TFL处理提示词模板",
      "description": "用于TFL表格数据分析处理的提示词模板",
      "usage": "TFL表格数据分析处理",
      "used_by": ["TFLProcessingService"],
      "template": {
        "md_file": "prompt/tfl_processing_prompt.md"
      },
      "variables": ["user_prompt", "example_template", "content"]
    },
    "tfl_verification": {
      "name": "TFL验证提示词模板",
      "description": "用于验证多个模型分析结果的提示词模板",
      "usage": "验证多个模型的分析结果",
      "used_by": ["TFLProcessingService"],
      "template": {
        "md_file": "prompt/tfl_validate_prompt.md"
      },
      "variables": ["results"]
    }
    ,
    "csr_generation": {
      "name": "CSR生成提示词模板",
      "description": "用于根据提取数据生成CSR段落的提示词模板",
      "usage": "CSR段落生成",
      "used_by": ["ContentGenerator"],
      "template": {
        "md_file": "../generation/paragraph.md"
      },
      "variables": ["generate_prompt", "scheme_data", "example", "project_desc"]
    }
    ,
    "data_source_validation": {
      "name": "数据源校验提示词模板",
      "description": "根据用户的校验逻辑（Rules）和文件名称列表，对各分类的数据源是否符合进行校验（语义+命名规范）",
      "usage": "数据源命名与分类校验",
      "used_by": ["DataSourceValidator"],
      "template": {
        "md_file": "../validation/data_source_validation.md"
      },
      "variables": ["rules", "files", "project_desc"]
    },
    "data_source_matching": {
      "name": "数据源匹配提示词模板",
      "description": "根据用户的匹配规则（Rules），从文件列表中找出所有符合要求的文件",
      "usage": "数据源文件匹配",
      "used_by": ["DataSourceValidator"],
      "template": {
        "md_file": "../validation/data_source_matching.md"
      },
      "variables": ["category_list", "project_desc"]
    },
    "chunk_filtering": {
      "name": "分块筛选提示词模板",
      "description": "根据用户的提取需求，从文档分块中筛选出最相关的分块",
      "usage": "智能分块筛选",
      "used_by": ["TwoStageExtractionService"],
      "template": {
        "md_file": "../filtering/chunk_filtering.md"
      },
      "variables": ["extraction_query", "chunks_list", "project_desc"]
    },
    "chunk_based_extraction": {
      "name": "基于分块的内容提取模板（Word）",
      "description": "从筛选出的相关分块中提取用户所需信息",
      "usage": "Word文档分块内容提取",
      "used_by": ["TwoStageExtractionService"],
      "template": {
        "md_file": "../extraction/chunk_based.md"
      },
      "variables": ["extraction_query", "selected_chunks_content", "project_desc"]
    },
    "chunk_filtering_pdf": {
      "name": "PDF文档分块筛选提示词模板",
      "description": "根据用户的提取需求，从PDF文档分块中筛选出最相关的分块，考虑OCR识别特点",
      "usage": "PDF文档智能分块筛选",
      "used_by": ["TwoStageExtractionService"],
      "template": {
        "md_file": "../filtering/chunk_filtering_pdf.md"
      },
      "variables": ["extraction_query", "chunks_list", "project_desc"]
    },
    "chunk_based_extraction_pdf": {
      "name": "基于分块的内容提取模板（PDF）",
      "description": "从PDF文档筛选出的相关分块中提取用户所需信息，容错OCR识别误差",
      "usage": "PDF文档分块内容提取",
      "used_by": ["TwoStageExtractionService"],
      "template": {
        "md_file": "../extraction/chunk_based_pdf.md"
      },
      "variables": ["extraction_query", "selected_chunks_content", "project_desc"]
    },
    "excel_extraction": {
      "name": "Excel数据提取模板",
      "description": "从Excel的Sheet内容（Markdown格式）中提取用户所需的数据和信息",
      "usage": "Excel表格数据提取",
      "used_by": ["ExcelExtractionService"],
      "template": {
        "md_file": "../extraction/excel_extraction_prompt.md"
      },
      "variables": ["extraction_query", "sheet_name", "source_file", "sheet_content", "project_desc"]
    },
    "extraction_validation": {
      "name": "提取结果校验模板",
      "description": "校验提取结果的准确性、完整性、格式规范和逻辑一致性，判断是否需要重新提取",
      "usage": "提取结果质量校验",
      "used_by": ["ExtractionValidationService"],
      "template": {
        "md_file": "../validation/extraction_validation_prompt.md"
      },
      "variables": ["extraction_query", "source_content", "extracted_content"]
    },
    "chunk_section_summary": {
    "name": "分块章节摘要模板",
    "description": "为分块后的章节内容生成摘要的提示词模板",
    "usage": "Word/PDF文档分块摘要生成",
    "used_by": ["HeadingBasedChunker"],
    "template": {
      "md_file": "../summary/chunk_section_summary.md"
    },
    "variables": ["title", "content"]
    }
  }
}